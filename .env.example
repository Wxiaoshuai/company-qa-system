APP_NAME=Company QA System
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

OPENAI_API_KEY=
OPENAI_BASE_URL=

EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

AUTH_DB_PATH=data/auth.db
AUTH_SESSION_COOKIE_NAME=company_qa_session
# AUTH_SESSION_SECRET=  # 必填！请填写一个随机字符串，如 python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_INIT_ADMIN_ENABLED=true
AUTH_INIT_ADMIN_USERNAME=admin
AUTH_INIT_ADMIN_PASSWORD=ChangeMe123!
AUTH_INIT_ADMIN_DISPLAY_NAME=System Admin
AUTH_INIT_ADMIN_RESET_PASSWORD=false  # 设为true可强制重置管理员密码

RAG_ENGINE=auto
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
RAG_VECTOR_INDEX_PATH=data/vector_store/index.json
RAG_LLAMAINDEX_PERSIST_DIR=data/vector_store/llamaindex
